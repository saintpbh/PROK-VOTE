# ============================================================
# PROK Vote — 프로덕션 환경변수 (.env.production)
# ============================================================
# 이 파일을 .env.production으로 복사 후 실제 값으로 변경하세요.
# ⚠️ .env.production 파일은 절대 Git에 커밋하지 마세요!
# ============================================================

# ──────────────────────────────────────────────
# 데이터베이스 (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_USER=prok_admin
DATABASE_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DATABASE_NAME=prok_vote

# ──────────────────────────────────────────────
# JWT (보안 토큰)
# ──────────────────────────────────────────────
# 생성 방법: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_BYTES_BASE64
JWT_EXPIRATION=2h

# ──────────────────────────────────────────────
# 프론트엔드 URL (CORS 허용)
# ──────────────────────────────────────────────
FRONTEND_URL=https://vote.prok.org
PRODUCTION_URL=https://vote.prok.org

# ──────────────────────────────────────────────
# 프론트엔드 빌드 변수
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://vote-api.prok.org
NEXT_PUBLIC_WS_URL=https://vote-api.prok.org
NEXT_PUBLIC_BASE_URL=https://vote.prok.org

# ──────────────────────────────────────────────
# GPS 설정
# ──────────────────────────────────────────────
DEFAULT_GPS_RADIUS=100

# ──────────────────────────────────────────────
# 접속 코드 TTL (초)
# ──────────────────────────────────────────────
ACCESS_CODE_TTL=3600

# ──────────────────────────────────────────────
# Super Admin 비밀번호
# ──────────────────────────────────────────────
SUPER_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_ADMIN_PASSWORD
